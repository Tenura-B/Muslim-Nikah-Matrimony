# ─── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — app WILL NOT START without this
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/muslim_nikah"

# JWT signing secret — MUST be at least 32 characters — change this in production!
JWT_SECRET="change-me-to-a-random-64-char-secret-in-production"

# ─── Optional (with defaults) ─────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
JWT_EXPIRES_IN=7d

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─── Stripe (required only if payment gateway is enabled) ─────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
